# Google Maps JavaScript API Key (for map tiles + Places)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_maps_js_api_key_here

# Google Places API Key
NEXT_PUBLIC_GOOGLE_PLACES_KEY=your_places_api_key_here

# Google Directions API Key (server-side only — NOT prefixed with NEXT_PUBLIC_)
GOOGLE_DIRECTIONS_KEY=your_directions_api_key_here
